# Flat node_modules (like npm), not pnpm's default symlinked/isolated layout.
# electron-builder packages `node_modules/**` into the asar and does NOT resolve
# pnpm's .pnpm symlink store, so a transitive native dep like better-sqlite3's
# `bindings` ends up unreachable at runtime ("Cannot find module 'bindings'").
# Hoisting puts every dependency at the top level so the packaged app resolves them.
node-linker=hoisted
